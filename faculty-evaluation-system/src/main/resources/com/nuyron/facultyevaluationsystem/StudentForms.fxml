<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="460.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nuyron.facultyevaluationsystem.controller.StudentFormsController">
    <top>
        <HBox spacing="12.0" style="-fx-background-color: #426c7a; -fx-padding: 12;">
            <children>
                <Button mnemonicParsing="false" onAction="#onBackClick" style="-fx-background-color: #155870; -fx-text-fill: #e0e4ee; -fx-background-radius: 14;" text="Back to Dashboard" />
                <Label text="Available Scheduled Forms" textFill="#e0e4ee">
                    <font>
                        <Font name="Cal Sans Regular" size="18.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>
    <center>
        <AnchorPane>
            <children>
                <TableView fx:id="formsTableView" layoutX="20.0" layoutY="20.0" prefHeight="330.0" prefWidth="680.0">
                    <columns>
                        <TableColumn fx:id="formNameCol" prefWidth="150.0" text="Form Name" />
                        <TableColumn fx:id="deptCol" prefWidth="120.0" text="Department" />
                        <TableColumn fx:id="courseCol" prefWidth="100.0" text="Course" />
                        <TableColumn fx:id="semesterCol" prefWidth="130.0" text="Semester" />
                        <TableColumn fx:id="endDateCol" prefWidth="150.0" text="Due Date" />
                    </columns>
                </TableView>
                <Button layoutX="580.0" layoutY="365.0" mnemonicParsing="false" onAction="#onFillFormClick" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: #425D6A; -fx-text-fill: white;" text="Fill Form" />
                <Label fx:id="statusLabel" layoutX="20.0" layoutY="370.0" textFill="RED">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>
    </center>
</BorderPane>
