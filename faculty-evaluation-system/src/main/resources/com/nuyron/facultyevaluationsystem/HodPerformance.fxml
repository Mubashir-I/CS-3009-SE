<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<TabPane tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nuyron.facultyevaluationsystem.controller.HodPerformanceController" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
   <tabs>
      <Tab text="High Performer">
         <content>
            <AnchorPane>
               <children>
                  <VBox spacing="10.0"
                        AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0"
                        AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Select Course:" style="-fx-text-fill: #425d6a; -fx-font-family: 'Cal Sans Regular';" />
                              <ComboBox fx:id="hpCourseComboBox" prefWidth="280.0" onAction="#onHpCourseChanged" />
                           </children>
                           <padding><Insets bottom="5.0" /></padding>
                        </VBox>
                        <Label fx:id="hpStatusLabel" style="-fx-text-fill: #888; -fx-font-size: 12;" />
                        <BarChart fx:id="highPerformerChart" VBox.vgrow="ALWAYS" animated="true"
                                  title="Overall Average Score per Instructor">
                           <xAxis><CategoryAxis label="Instructor" /></xAxis>
                           <yAxis><NumberAxis label="Overall Avg Score (0–100)" lowerBound="0" upperBound="100" tickUnit="10" autoRanging="false" /></yAxis>
                        </BarChart>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </content>
      </Tab>
      <Tab text="Instructor Analysis">
         <content>
            <AnchorPane>
               <children>
                  <VBox spacing="10.0"
                        AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0"
                        AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Select Course:" style="-fx-text-fill: #425d6a; -fx-font-family: 'Cal Sans Regular';" />
                              <ComboBox fx:id="iaCourseComboBox" prefWidth="280.0" onAction="#onIaCourseChanged" />
                           </children>
                           <padding><Insets bottom="5.0" /></padding>
                        </VBox>
                        <Label fx:id="iaStatusLabel" style="-fx-text-fill: #888; -fx-font-size: 12;" />
                        <BarChart fx:id="instructorAnalysisChart" VBox.vgrow="ALWAYS" animated="true"
                                  title="Score per Performance Factor per Instructor">
                           <xAxis><CategoryAxis label="Performance Factor" /></xAxis>
                           <yAxis><NumberAxis label="Avg Score (0–100)" lowerBound="0" upperBound="100" tickUnit="10" autoRanging="false" /></yAxis>
                        </BarChart>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
         </content>
      </Tab>
   </tabs>
</TabPane>
