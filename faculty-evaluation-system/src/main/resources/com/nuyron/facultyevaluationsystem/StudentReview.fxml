<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="460.0" prefWidth="720.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nuyron.facultyevaluationsystem.controller.StudentReviewController">

    <!-- TOP -->
    <top>
        <HBox nodeOrientation="LEFT_TO_RIGHT" spacing="20" style="-fx-background-color: #426c7a; -fx-padding: 15;">
            <Button mnemonicParsing="false" onAction="#onBackClick" style="-fx-background-color: #155870; -fx-text-fill: #e0e4ee; -fx-background-radius: 14;" text="Back" />
            <Label text="Faculty Feedback Form" textFill="WHITE">
                <font><Font name="Cal Sans Regular" size="18.0" /></font>
            </Label>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">

            <Label fx:id="enrollmentContextLabel" style="-fx-font-size: 12px; -fx-font-weight: bold;" textFill="#425d6a" />

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Rate each item from 1 (Very Poor) to 5 (Excellent):" />

            <GridPane hgap="14" vgap="10">
                <Label text="Clarity" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ComboBox fx:id="clarityComboBox" prefWidth="140" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Difficulty" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ComboBox fx:id="difficultyComboBox" prefWidth="140" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Fairness" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="fairnessComboBox" prefWidth="140" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Engagement" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <ComboBox fx:id="engagementComboBox" prefWidth="140" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Workload" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <ComboBox fx:id="workloadComboBox" prefWidth="140" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label text="Tags (optional)" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <TextField fx:id="tagsField" promptText="e.g. helpful,clear,interactive" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            </GridPane>

            <Label text="Comments (optional)" />
            <TextArea fx:id="commentsArea" prefHeight="110" wrapText="true" />

            <Button onAction="#handleSubmit" style="-fx-background-color: #426c7a; -fx-text-fill: white;" text="Submit Feedback" />

            <Label fx:id="statusLabel" textFill="RED" />

        </VBox>
    </center>

</BorderPane>
