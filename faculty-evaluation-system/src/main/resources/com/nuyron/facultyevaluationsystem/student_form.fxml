        </Label>
        <Label text="Student Batch" GridPane.rowIndex="3">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        <Label text="Department ID" GridPane.rowIndex="4">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <TextField fx:id="rollNoField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <TextField fx:id="batchField" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <TextField fx:id="deptIdField" GridPane.columnIndex="1" GridPane.rowIndex="4" />

        <Button fx:id="StudentFormSubmissionButton" mnemonicParsing="false" onAction="#handleSubmission" text="Submit" GridPane.columnIndex="2" GridPane.rowIndex="5">
            <font>
                <Font size="16.0" />
            </font>
