                        </Label>
                        <ComboBox fx:id="departmentComboBox" prefHeight="25.0" prefWidth="185.0" />
                        <Button fx:id="addUserButton" mnemonicParsing="false" onMouseClicked="#onClickAddUser" text=" Add user">
