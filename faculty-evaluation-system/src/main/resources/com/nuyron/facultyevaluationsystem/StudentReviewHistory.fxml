<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="460.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nuyron.facultyevaluationsystem.controller.StudentReviewHistoryController">
    <top>
        <HBox spacing="12.0" style="-fx-background-color: #426c7a; -fx-padding: 12;">
            <children>
                <Button mnemonicParsing="false" onAction="#onBackClick" style="-fx-background-color: #155870; -fx-text-fill: #e0e4ee; -fx-background-radius: 14;" text="Back" />
                <Label text="Your Feedback History" textFill="#e0e4ee">
                    <font>
                        <Font name="Cal Sans Regular" size="18.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>
    <center>
        <AnchorPane>
            <children>
                <TableView fx:id="historyTableView" layoutX="20.0" layoutY="20.0" prefHeight="360.0" prefWidth="680.0">
                    <columns>
                        <TableColumn fx:id="teacherColumn" prefWidth="220.0" text="Teacher" />
                        <TableColumn fx:id="courseColumn" prefWidth="270.0" text="Course" />
                        <TableColumn fx:id="dateColumn" prefWidth="190.0" text="Date" />
                    </columns>
                </TableView>

                <Label fx:id="statusLabel" layoutX="20.0" layoutY="390.0" textFill="RED">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>
    </center>
</BorderPane>

